          "engine": "KaraokeReadingEngine",
          "icons": [
            5,
            6
          ],
          "content": {
            "instruction": "Listen and read Emilio’s class assignment.",
            "audio_url": "/assets/audio/u1_emilio_reading.mp3",
            "text": "My father is tall. He’s got short, brown hair and brown eyes. He’s got a beard. My mother is average height. She’s got curly hair and blue eyes. She’s got a birthmark on her arm.",
