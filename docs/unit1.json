          }
        },
        {
          "id": "act_strategy_1",
          "type": "Reading Strategy",
          "title": "Scanning",
          "engine": "SpotlightEngine",
          "icons": [
            6,
            7
          ],
          "content": {
            "instruction": "Scanning: You don’t always need to understand every word. Find the specific words.",
            "tasks": [
              {
                "prompt": "Find the word 'beard'",
                "target_text": "beard"
              },
              {
                "prompt": "Find the word 'curly hair'",
                "target_text": "curly hair"
              }
            ]
          }
        }
      ]
    },
